{
  "name": "quantum-ide",
  "version": "1.0.0",
  "description": "Desktop quantum computing IDE with a custom assembly language, hand-rolled state-vector simulator, circuit diagram, and Bloch sphere visualization",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k -n VITE,ELECTRON -c cyan,magenta \"vite\" \"wait-on http://localhost:3000 && electron . --dev\""
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "vite": "^6.0.0",
    "wait-on": "^9.0.5"
  }
}
